generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EventoAuditoria {
  id_evento         Int         @id @default(autoincrement())
  ts_data_ocorreu   DateTime    @map("ts_data_ocorreu")
  id_usuario        Int         @map("id_usuario")
  id_cliente        Int         @map("id_cliente")
  tipo_evento       String      @map("tipo_evento")
  ip_origem         String      @map("ip_origem")
  st_criticidade    Criticidade @map("st_criticidade")
  st_resultado      Resultado   @map("st_resultado")
  id_correlacao     String?     @map("id_correlacao")
  id_entidade       String?     @map("id_entidade")
  detalhes_json     Json?       @map("detalhes_json")
  ts_data_cadastro  DateTime    @map("ts_data_cadastro")
  usuario_adicionou String      @map("usuario_adicionou")
  usuario_alterou   String      @map("usuario_alterou")

  @@map("tb_eventos_auditoria")
}

enum Criticidade {
  ALTA
  MEDIA
  BAIXA
}

enum Resultado {
  SUCESSO
  FALHA
}
