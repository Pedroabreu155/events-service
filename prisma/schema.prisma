generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EventoAuditoria {
  id_event       Int      @id @default(autoincrement())
  ts_transaction DateTime @map("ts_transaction")
  id_user        Int      @map("id_user")
  id_company     Int      @map("id_company")
  tp_event       String   @map("tp_event")
  ip_host        String   @map("ip_host")
  id_severity    Severity @map("id_severity")
  id_result      Result   @map("id_result")
  id_correlation String?  @map("id_correlation")
  id_entity      String?  @map("id_entity")
  js_detail      Json?    @map("js_detail")
  ts_created_at  DateTime @map("ts_created_at")
  created_by     String   @map("id_created_by")
  updated_by     String   @map("id_updated_by")

  @@index([id_company, ts_transaction])
  @@index([id_user, ts_transaction])
  @@index([tp_event, ts_transaction])
  @@map("tb_eventos_auditoria")
}

enum Severity {
  HIGH
  MEDIUM
  LOW
}

enum Result {
  SUCCESS
  FAILURE
}
